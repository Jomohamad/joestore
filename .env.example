# Supabase Configuration (replace with your own values)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Payment Provider APIs (obtain from respective providers)
RELOADLY_CLIENT_ID=your-client-id-here
RELOADLY_CLIENT_SECRET=your-client-secret-here

GAMESDROP_API_KEY=your-api-key-here
UNIPIN_API_KEY=your-api-key-here
SEAGM_API_KEY=your-api-key-here
DRIFFLE_API_KEY=your-api-key-here

FAWATERK_API_KEY=your-api-key-here
FAWATERK_SECRET_KEY=your-secret-key-here
FAWATERK_SECRET=your-secret-here
FAWATERK_WEBHOOK_SECRET=your-webhook-secret-here

# Application Secrets (generate secure random values)
JWT_SECRET=your-secure-jwt-secret-here
INTERNAL_API_TOKEN=your-internal-api-token-here

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# Queue Configuration
QUEUE_MODE=bullmq
RABBITMQ_URL=amqp://localhost:5672
BULLMQ_PREFIX=joestore
TOPUP_JOB_ATTEMPTS=3
TOPUP_JOB_BACKOFF_MS=2000

# Geolocation API (optional)
GEOLOCATION_API_BASE=https://ipapi.co
GEOLOCATION_API_KEY=your-geolocation-api-key-here

# Fraud Detection Settings
FRAUD_MAX_ORDERS_PER_MINUTE=6
FRAUD_BLOCK_RISK_SCORE=80

# Optional runtime config
APP_BASE_URL=http://localhost:3000
SANDBOX_MODE=true
ALLOW_SYNC_TOPUP_FALLBACK=true
RELOADLY_AUTH_BASE=https://auth.reloadly.com
RELOADLY_TOPUPS_BASE=https://topups.reloadly.com
GAMESDROP_API_BASE=https://api.gamesdrop.com/v1
UNIPIN_API_BASE=https://api.unipin.com/v1
SEAGM_API_BASE=https://api.seagm.com/v1
DRIFFLE_API_BASE=https://api.driffle.com/v1
PROVIDER_TIMEOUT_MS=15000
