# ========================================
# Cache & Queue Configuration
# ========================================
REDIS_URL=your-redis-url
REDIS_TLS=false
QUEUE_MODE=bullmq
RABBITMQ_URL=your-rabbitmq-url
BULLMQ_PREFIX=joestore
TOPUP_JOB_ATTEMPTS=3
TOPUP_JOB_BACKOFF_MS=2000

# ========================================
# Geolocation & Fraud Prevention
# ========================================
GEOLOCATION_API_BASE=https://ipapi.co
GEOLOCATION_API_KEY=your-geolocation-api-key
FRAUD_MAX_ORDERS_PER_MINUTE=6
FRAUD_BLOCK_RISK_SCORE=80

# ========================================
# Operational Settings
# ========================================
SANDBOX_MODE=true
ALLOW_SYNC_TOPUP_FALLBACK=true
PROVIDER_TIMEOUT_MS=15000

# ========================================
# Alerting (Optional)
# ========================================
ALERT_WEBHOOK_URL=your-alert-webhook-url
