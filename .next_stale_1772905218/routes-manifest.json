    },
    {
      "page": "/orders",
      "regex": "^/orders(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/orders(?:/)?$"
    }
  ],
  "dataRoutes": [
    {
      "page": "/admin",
      "dataRouteRegex": "^/_next/data/zjCnYqpP4Y6iqO3awrwzR/admin\\.json$"
    },
    {
      "page": "/game/[id]",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "dataRouteRegex": "^/_next/data/zjCnYqpP4Y6iqO3awrwzR/game/([^/]+?)\\.json$",
      "namedDataRouteRegex": "^/_next/data/zjCnYqpP4Y6iqO3awrwzR/game/(?<nxtPid>[^/]+?)\\.json$"
    },
    {
      "page": "/order/[id]",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "dataRouteRegex": "^/_next/data/zjCnYqpP4Y6iqO3awrwzR/order/([^/]+?)\\.json$",
      "namedDataRouteRegex": "^/_next/data/zjCnYqpP4Y6iqO3awrwzR/order/(?<nxtPid>[^/]+?)\\.json$"
    },
    {
      "page": "/orders",
      "dataRouteRegex": "^/_next/data/zjCnYqpP4Y6iqO3awrwzR/orders\\.json$"
    },
    {
      "page": "/product/[id]",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "dataRouteRegex": "^/_next/data/zjCnYqpP4Y6iqO3awrwzR/product/([^/]+?)\\.json$",
      "namedDataRouteRegex": "^/_next/data/zjCnYqpP4Y6iqO3awrwzR/product/(?<nxtPid>[^/]+?)\\.json$"
    }
  ],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
