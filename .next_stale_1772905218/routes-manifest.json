      "namedRegex": "^/admin/settings(?:/)?$"
    },
    {
      "page": "/admin/transactions",
      "regex": "^/admin/transactions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/transactions(?:/)?$"
    },
    {
      "page": "/admin/users",
      "regex": "^/admin/users(?:/)?$",
      "routeKeys": {},
