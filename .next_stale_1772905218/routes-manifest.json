      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/product/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[[...slug]]",
      "regex": "^(?:/(.+?))?(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^(?:/(?<nxtPslug>.+?))?(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/admin/api-monitor",
      "regex": "^/admin/api\\-monitor(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/api\\-monitor(?:/)?$"
    },
    {
      "page": "/admin/dashboard",
